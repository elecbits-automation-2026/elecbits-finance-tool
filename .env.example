# Supabase config — copy this file to .env.local and fill in real values.
# Project Settings -> API in your Supabase dashboard.
# NOTE: use the API URL (…​.supabase.co), NOT the dashboard URL.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed to run scripts/seed.ts (server-side). NEVER expose this in the browser
# or commit it. Project Settings -> API -> service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Password for the dedicated admin account (login username: "admin").
# Used by scripts/seed.ts; re-run `npm run seed` to rotate it. Defaults to
# admin@123 if unset — set a strong value for any real deployment.
ADMIN_PASSWORD=admin@123
